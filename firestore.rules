rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    
    function isBootstrappedAdmin() {
      // Allow specific email as bootstrapped admin
      return isSignedIn() && request.auth.token.email == 'asngad@mhs.unugha.ac.id' && request.auth.token.email_verified == true;
    }

    function isAuthorizedAdmin() {
      return isAdmin() || isBootstrappedAdmin();
    }

    // Validation Blueprint for Product
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'desc', 'price', 'img', 'createdAt', 'updatedAt']) 
          && data.keys().size() == 6
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.desc is string && data.desc.size() > 0 && data.desc.size() <= 1000
          && data.price is string && data.price.size() > 0 && data.price.size() <= 50
          && data.img is string && data.img.size() > 0 && data.img.size() <= 1000
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    match /admins/{userId} {
      allow get: if isAuthorizedAdmin();
      allow list: if isAuthorizedAdmin() && userId == request.auth.uid;
      // No writes via client
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true; // Everyone can read products

      allow create: if isAuthorizedAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isAuthorizedAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'desc', 'price', 'img', 'updatedAt']);

      allow delete: if isAuthorizedAdmin() && isValidId(productId);
    }
  }
}
